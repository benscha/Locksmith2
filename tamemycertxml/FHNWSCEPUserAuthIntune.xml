<CertificateRequestPolicy xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema">
  <AuditOnly>false</AuditOnly>
  <Subject>
    <SubjectRule>
      <Field>commonName</Field>
      <Mandatory>true</Mandatory>
      <Patterns>
        <Pattern>
          <Expression>^[a-zA-Z0-9\.]*\@(fhnw|mab\-bs)\.ch$</Expression>
        </Pattern>
      </Patterns>
    </SubjectRule>
    <SubjectRule>
      <Field>emailAddress</Field>
      <Mandatory>true</Mandatory>
      <Patterns>
        <Pattern>
          <Expression>^[a-zA-Z0-9\.]*\@(fhnw|mab\-bs)\.ch$</Expression>
        </Pattern>
      </Patterns>
    </SubjectRule>
  </Subject>
  <SubjectAlternativeName>
    <SubjectRule>
      <Field>userPrincipalName</Field>
      <Mandatory>true</Mandatory>
      <Patterns>
        <Pattern>
          <Expression>^[a-zA-Z0-9\.]*\@(fhnw|mab\-bs)\.ch$</Expression>
        </Pattern>
      </Patterns>
    </SubjectRule>
  </SubjectAlternativeName>
  <DirectoryServicesMapping>
    <SearchRoot>OU=adm,OU=Prod,DC=adm,DC=ds,DC=fhnw,DC=ch</SearchRoot>
    <AllowedSecurityGroups>
      <string>CN=G_A11_ActiveStaff,OU=O365,OU=application_settings,OU=groups,OU=adm,OU=Prod,DC=adm,DC=ds,DC=fhnw,DC=ch</string>
    </AllowedSecurityGroups>
    <DisallowedSecurityGroups>
      <string>CN=Enterprise Admins,CN=Users,DC=ds,DC=fhnw,DC=ch</string>     
      <string>CN=Schema Admins,CN=Users,DC=ds,DC=fhnw,DC=ch</string>   
      <string>CN=Backup Operators,CN=Builtin,DC=ds,DC=fhnw,DC=ch</string>  
      <string>CN=Backup Operators,CN=Builtin,DC=adm,DC=ds,DC=fhnw,DC=ch</string>  
      <string>CN=Backup Operators,CN=Builtin,DC=edu,DC=ds,DC=fhnw,DC=ch</string>  
      <string>CN=Domain Admins,CN=Users,DC=ds,DC=fhnw,DC=ch</string> 
      <string>CN=Domain Admins,CN=Users,DC=adm,DC=ds,DC=fhnw,DC=ch</string>
      <string>CN=Domain Admins,CN=Users,DC=edu,DC=ds,DC=fhnw,DC=ch</string>
      <string>CN=Administrators,CN=Builtin,DC=ds,DC=fhnw,DC=ch</string>
      <string>CN=Administrators,CN=Builtin,DC=adm,DC=ds,DC=fhnw,DC=ch</string>
      <string>CN=Administrators,CN=Builtin,DC=edu,DC=ds,DC=fhnw,DC=ch</string>
    </DisallowedSecurityGroups>  
  </DirectoryServicesMapping>
</CertificateRequestPolicy>